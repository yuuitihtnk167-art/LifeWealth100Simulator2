{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start local web server",
      "type": "process",
      "command": "C:\\Python314\\python.exe",
      "args": [
        "-u",
        "-m",
        "http.server",
        "8081"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP on"
        }
      }
    }
  ]
}
